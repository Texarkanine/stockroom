        "contents": "\"\"\"Application configuration.\n\nThis module centralizes every tunable knob for the application. Each setting is\ndocumented with its purpose, default, and the environment variable that\noverrides it. Kept content like this must round-trip byte-identical through the\nwarehouse: no truncation at rest.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nfrom dataclasses import dataclass\n\n\n@dataclass(frozen=True)\nclass Settings:\n    host: str = os.getenv(\"APP_HOST\", \"127.0.0.1\")\n    port: int = int(os.getenv(\"APP_PORT\", \"8080\"))\n    debug: bool = os.getenv(\"APP_DEBUG\", \"0\") == \"1\"\n    db_url: str = os.getenv(\"APP_DB_URL\", \"duckdb:///app.duckdb\")\n    cache_ttl: int = int(os.getenv(\"APP_CACHE_TTL\", \"300\"))\n    max_workers: int = int(os.getenv(\"APP_MAX_WORKERS\", \"4\"))\n    log_level: str = os.getenv(\"APP_LOG_LEVEL\", \"INFO\")\n    feature_search: bool = os.getenv(\"APP_FEATURE_SEARCH\", \"1\") == \"1\"\n    feature_embeddings: bool = os.getenv(\"APP_FEATURE_EMBEDDINGS\", \"0\") == \"1\"\n    embed_model: str = os.getenv(\"APP_EMBED_MODEL\", \"all-MiniLM-L6-v2\")\n    embed_dim: int = int(os.getenv(\"APP_EMBED_DIM\", \"384\"))\n    chunk_size: int = int(os.getenv(\"APP_CHUNK_SIZE\", \"512\"))\n    chunk_overlap: int = int(os.getenv(\"APP_CHUNK_OVERLAP\", \"64\"))\n\n\ndef load() -> Settings:\n    \"\"\"Build a Settings instance from the current environment.\"\"\"\n    return Settings()\n\n\nif __name__ == \"__main__\":\n    import json\n    print(json.dumps(load().__dict__, indent=2))\n",
